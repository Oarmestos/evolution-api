generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_CONNECTION_URI")
}

model Instance {
  id                      String                   @id @default(cuid())
  name                    String                   @unique @db.VarChar(255)
  connectionStatus        InstanceConnectionStatus @default(open)
  ownerJid                String?                  @db.VarChar(100)
  profilePicUrl           String?                  @db.VarChar(500)
  integration             String?                  @db.VarChar(100)
  number                  String?                  @db.VarChar(100)
  token                   String?                  @db.VarChar(255)
  clientName              String?                  @db.VarChar(100)
  createdAt               DateTime?                @default(now()) @db.Timestamp(6)
  updatedAt               DateTime?                @updatedAt @db.Timestamp(6)
  profileName             String?                  @db.VarChar(100)
  businessId              String?                  @db.VarChar(100)
  disconnectionAt         DateTime?                @db.Timestamp(6)
  disconnectionObject     Json?
  disconnectionReasonCode Int?
  userId                  String?
  Chat                    Chat[]
  Chatwoot                Chatwoot?
  Contact                 Contact[]
  Dify                    Dify[]
  DifySetting             DifySetting?
  Evoai                   Evoai[]
  EvoaiSetting            EvoaiSetting?
  EvolutionBot            EvolutionBot[]
  EvolutionBotSetting     EvolutionBotSetting?
  Flowise                 Flowise[]
  FlowiseSetting          FlowiseSetting?
  User                    User?                    @relation(fields: [userId], references: [id])
  IntegrationSession      IntegrationSession[]
  Kafka                   Kafka?
  Label                   Label[]
  Lead                    Lead[]
  LeadFunnel              LeadFunnel[]
  Media                   Media[]
  Message                 Message[]
  MessageUpdate           MessageUpdate[]
  N8n                     N8n[]
  N8nSetting              N8nSetting?
  Nats                    Nats?
  OpenaiBot               OpenaiBot[]
  OpenaiCreds             OpenaiCreds[]
  OpenaiSetting           OpenaiSetting?
  Proxy                   Proxy?
  Pusher                  Pusher?
  Rabbitmq                Rabbitmq?
  Session                 Session?
  Setting                 Setting?
  Sqs                     Sqs?
  Template                Template[]
  Typebot                 Typebot[]
  TypebotSetting          TypebotSetting?
  Webhook                 Webhook?
  Websocket               Websocket?
  Product                 Product[]
  Order                   Order[]
  storeTheme              StoreTheme?
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique @db.VarChar(255)
  password      String         @db.VarChar(255)
  name          String?        @db.VarChar(255)
  role          UserRole       @default(USER)
  createdAt     DateTime       @default(now()) @db.Timestamp(6)
  updatedAt     DateTime       @updatedAt @db.Timestamp(6)
  instances     Instance[]
  internalNotes InternalNote[]
  subscription  Subscription?
}

model StoreTheme {
  id           String   @id @default(cuid())
  instanceId   String   @unique
  template     String   @default("moderno") @db.VarChar(50)
  storeName    String?  @db.VarChar(100)
  logoUrl      String?  @db.VarChar(500)
  heroTitle    String?  @db.VarChar(100)
  heroSubtitle String?  @db.VarChar(255)
  heroImageUrl String?  @db.VarChar(500)
  footerText   String?  @db.VarChar(255)
  primaryColor String   @default("#6366f1") @db.VarChar(20)
  buttonColor  String   @default("#000000") @db.VarChar(20)
  bgColor      String   @default("#f8fafc") @db.VarChar(20)
  fontFamily   String   @default("Inter") @db.VarChar(50)
  ctaText      String   @default("Ver Detalles") @db.VarChar(100)
  borderRadius Int      @default(12)
  instagramUrl String?  @db.VarChar(500)
  tiktokUrl    String?  @db.VarChar(500)
  syncWhatsapp Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @db.Timestamp(6)
  Instance     Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
}

model Plan {
  id            String         @id @default(cuid())
  name          String         @unique @db.VarChar(100)
  description   String?        @db.VarChar(255)
  maxInstances  Int            @default(1)
  price         Float          @default(0.0)
  createdAt     DateTime       @default(now()) @db.Timestamp(6)
  updatedAt     DateTime       @updatedAt @db.Timestamp(6)
  subscriptions Subscription[]
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  planId    String
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now()) @db.Timestamp(6)
  endDate   DateTime?          @db.Timestamp(6)
  plan      Plan               @relation(fields: [planId], references: [id])
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  sessionId String   @unique
  creds     String?
  createdAt DateTime @default(now()) @db.Timestamp(6)
  Instance  Instance @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Chat {
  id             String          @id @default(cuid())
  remoteJid      String          @db.VarChar(100)
  labels         Json?
  createdAt      DateTime?       @default(now()) @db.Timestamp(6)
  updatedAt      DateTime?       @updatedAt @db.Timestamp(6)
  instanceId     String
  name           String?         @db.VarChar(100)
  unreadMessages Int             @default(0)
  controlMode    ChatControlMode @default(AI)
  lastMessage          Json?
  lastMessageTimestamp Int?
  Instance       Instance        @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  internalNotes  InternalNote[]

  @@unique([instanceId, remoteJid])
  @@index([instanceId])
  @@index([remoteJid])
}

model Contact {
  id            String    @id @default(cuid())
  remoteJid     String    @db.VarChar(100)
  pushName      String?   @db.VarChar(100)
  profilePicUrl String?   @db.VarChar(500)
  createdAt     DateTime? @default(now()) @db.Timestamp(6)
  updatedAt     DateTime? @updatedAt @db.Timestamp(6)
  instanceId    String
  email         String?   @db.VarChar(255)
  phoneNumber   String?   @db.VarChar(100)
  Instance      Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  Lead          Lead[]

  @@unique([instanceId, remoteJid])
  @@index([remoteJid])
  @@index([instanceId])
}

model Message {
  id                           String              @id @default(cuid())
  key                          Json
  keyId                        String              @db.VarChar(100)
  pushName                     String?             @db.VarChar(100)
  participant                  String?             @db.VarChar(100)
  messageType                  String              @db.VarChar(100)
  message                      Json
  contextInfo                  Json?
  source                       DeviceMessage
  messageTimestamp             Int
  chatwootMessageId            Int?
  chatwootInboxId              Int?
  chatwootConversationId       Int?
  chatwootContactInboxSourceId String?             @db.VarChar(100)
  chatwootIsRead               Boolean?
  instanceId                   String
  webhookUrl                   String?             @db.VarChar(500)
  sessionId                    String?
  status                       String?             @db.VarChar(30)
  Media                        Media?
  Instance                     Instance            @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  session                      IntegrationSession? @relation(fields: [sessionId], references: [id])
  MessageUpdate                MessageUpdate[]

  @@unique([instanceId, keyId])
  @@index([instanceId])
  @@index([keyId])
}

model MessageUpdate {
  id          String   @id @default(cuid())
  keyId       String   @db.VarChar(100)
  remoteJid   String   @db.VarChar(100)
  fromMe      Boolean
  participant String?  @db.VarChar(100)
  pollUpdates Json?
  status      String   @db.VarChar(30)
  messageId   String
  instanceId  String
  dateTime    DateTime @default(now()) @db.Timestamp(6)
  Instance    Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  Message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([messageId])
}

model LeadFunnel {
  id          String      @id @default(cuid())
  name        String      @db.VarChar(100)
  description String?     @db.VarChar(255)
  instanceId  String
  createdAt   DateTime    @default(now()) @db.Timestamp(6)
  updatedAt   DateTime    @updatedAt @db.Timestamp(6)
  Instance    Instance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stages      LeadStage[]

  @@index([instanceId])
}

model LeadStage {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(100)
  color     String?    @default("#00ff88") @db.VarChar(50)
  order     Int        @default(0)
  funnelId  String
  createdAt DateTime   @default(now()) @db.Timestamp(6)
  updatedAt DateTime   @updatedAt @db.Timestamp(6)
  leads     Lead[]
  Funnel    LeadFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@index([funnelId])
}

model Lead {
  id         String    @id @default(cuid())
  value      Float     @default(0.0)
  notes      String?
  stageId    String
  contactId  String
  instanceId String
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  Contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  Stage      LeadStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([stageId])
  @@index([contactId])
  @@index([instanceId])
}

model InternalNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt @db.Timestamp(6)
  chatId     String
  userId     String
  instanceId String
  remoteJid  String?  @db.VarChar(100)
  Chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([userId])
}

model Webhook {
  id              String    @id @default(cuid())
  url             String    @db.VarChar(500)
  enabled         Boolean?  @default(true)
  events          Json?
  webhookByEvents Boolean?  @default(false)
  webhookBase64   Boolean?  @default(false)
  createdAt       DateTime? @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  instanceId      String    @unique
  headers         Json?
  Instance        Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
}

model Chatwoot {
  id                      String    @id @default(cuid())
  enabled                 Boolean?  @default(true)
  accountId               String?   @db.VarChar(100)
  token                   String?   @db.VarChar(100)
  url                     String?   @db.VarChar(500)
  nameInbox               String?   @db.VarChar(100)
  signMsg                 Boolean?  @default(false)
  signDelimiter           String?   @db.VarChar(100)
  number                  String?   @db.VarChar(100)
  reopenConversation      Boolean?  @default(false)
  conversationPending     Boolean?  @default(false)
  mergeBrazilContacts     Boolean?  @default(false)
  importContacts          Boolean?  @default(false)
  importMessages          Boolean?  @default(false)
  daysLimitImportMessages Int?
  createdAt               DateTime? @default(now()) @db.Timestamp(6)
  updatedAt               DateTime  @updatedAt @db.Timestamp(6)
  instanceId              String    @unique
  logo                    String?   @db.VarChar(500)
  organization            String?   @db.VarChar(100)
  ignoreJids              Json?
  Instance                Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Label {
  id           String    @id @default(cuid())
  labelId      String?   @db.VarChar(100)
  name         String    @db.VarChar(100)
  color        String    @db.VarChar(100)
  predefinedId String?   @db.VarChar(100)
  createdAt    DateTime? @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @updatedAt @db.Timestamp(6)
  instanceId   String
  Instance     Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@unique([labelId, instanceId])
}

model Proxy {
  id         String    @id @default(cuid())
  enabled    Boolean   @default(false)
  host       String    @db.VarChar(100)
  port       String    @db.VarChar(100)
  protocol   String    @db.VarChar(100)
  username   String    @db.VarChar(100)
  password   String    @db.VarChar(100)
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Setting {
  id              String    @id @default(cuid())
  rejectCall      Boolean   @default(false)
  msgCall         String?   @db.VarChar(100)
  groupsIgnore    Boolean   @default(false)
  alwaysOnline    Boolean   @default(false)
  readMessages    Boolean   @default(false)
  readStatus      Boolean   @default(false)
  syncFullHistory Boolean   @default(false)
  createdAt       DateTime? @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  instanceId      String    @unique
  wavoipToken     String?   @db.VarChar(100)
  Instance        Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
}

model Rabbitmq {
  id         String    @id @default(cuid())
  enabled    Boolean   @default(false)
  events     Json
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Nats {
  id         String    @id @default(cuid())
  enabled    Boolean   @default(false)
  events     Json
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Sqs {
  id         String    @id @default(cuid())
  enabled    Boolean   @default(false)
  events     Json
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Kafka {
  id         String    @id @default(cuid())
  enabled    Boolean   @default(false)
  events     Json
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Websocket {
  id         String    @id @default(cuid())
  enabled    Boolean   @default(false)
  events     Json
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Pusher {
  id         String    @id @default(cuid())
  enabled    Boolean   @default(false)
  appId      String    @db.VarChar(100)
  key        String    @db.VarChar(100)
  secret     String    @db.VarChar(100)
  cluster    String    @db.VarChar(100)
  useTLS     Boolean   @default(false)
  events     Json
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  instanceId String    @unique
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Typebot {
  id              String           @id @default(cuid())
  enabled         Boolean          @default(true)
  url             String           @db.VarChar(500)
  typebot         String           @db.VarChar(100)
  expire          Int?             @default(0)
  keywordFinish   String?          @db.VarChar(100)
  delayMessage    Int?
  unknownMessage  String?          @db.VarChar(100)
  listeningFromMe Boolean?         @default(false)
  stopBotFromMe   Boolean?         @default(false)
  keepOpen        Boolean?         @default(false)
  createdAt       DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt       DateTime?        @updatedAt @db.Timestamp(6)
  triggerType     TriggerType?
  triggerOperator TriggerOperator?
  triggerValue    String?
  instanceId      String
  debounceTime    Int?
  ignoreJids      Json?
  description     String?          @db.VarChar(255)
  splitMessages   Boolean?         @default(false)
  timePerChar     Int?             @default(50)
  Instance        Instance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  TypebotSetting  TypebotSetting[]
}

model TypebotSetting {
  id                String    @id @default(cuid())
  expire            Int?      @default(0)
  keywordFinish     String?   @db.VarChar(100)
  delayMessage      Int?
  unknownMessage    String?   @db.VarChar(100)
  listeningFromMe   Boolean?  @default(false)
  stopBotFromMe     Boolean?  @default(false)
  keepOpen          Boolean?  @default(false)
  createdAt         DateTime? @default(now()) @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @db.Timestamp(6)
  instanceId        String    @unique
  debounceTime      Int?
  typebotIdFallback String?   @db.VarChar(100)
  ignoreJids        Json?
  splitMessages     Boolean?  @default(false)
  timePerChar       Int?      @default(50)
  Instance          Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  Fallback          Typebot?  @relation(fields: [typebotIdFallback], references: [id])
}

model Media {
  id         String    @id @default(cuid())
  fileName   String    @db.VarChar(500)
  type       String    @db.VarChar(100)
  mimetype   String    @db.VarChar(100)
  createdAt  DateTime? @default(now()) @db.Date
  messageId  String    @unique
  instanceId String
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  Message    Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model OpenaiCreds {
  id              String         @id @default(cuid())
  apiKey          String?        @unique @db.VarChar(255)
  createdAt       DateTime?      @default(now()) @db.Timestamp(6)
  updatedAt       DateTime       @updatedAt @db.Timestamp(6)
  instanceId      String
  name            String?        @unique @db.VarChar(255)
  OpenaiAssistant OpenaiBot[]
  Instance        Instance       @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  OpenaiSetting   OpenaiSetting?
}

model OpenaiBot {
  id                String           @id @default(cuid())
  assistantId       String?          @db.VarChar(255)
  model             String?          @db.VarChar(100)
  systemMessages    Json?
  assistantMessages Json?
  userMessages      Json?
  maxTokens         Int?
  expire            Int?             @default(0)
  keywordFinish     String?          @db.VarChar(100)
  delayMessage      Int?
  unknownMessage    String?          @db.VarChar(100)
  listeningFromMe   Boolean?         @default(false)
  stopBotFromMe     Boolean?         @default(false)
  keepOpen          Boolean?         @default(false)
  debounceTime      Int?
  ignoreJids        Json?
  triggerType       TriggerType?
  triggerOperator   TriggerOperator?
  triggerValue      String?
  createdAt         DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt         DateTime         @updatedAt @db.Timestamp(6)
  openaiCredsId     String
  instanceId        String
  enabled           Boolean          @default(true)
  botType           OpenaiBotType
  description       String?          @db.VarChar(255)
  functionUrl       String?          @db.VarChar(500)
  splitMessages     Boolean?         @default(false)
  timePerChar       Int?             @default(50)
  Instance          Instance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  OpenaiCreds       OpenaiCreds      @relation(fields: [openaiCredsId], references: [id], onDelete: Cascade)
  OpenaiSetting     OpenaiSetting[]
}

model IntegrationSession {
  id         String        @id @default(cuid())
  sessionId  String        @db.VarChar(255)
  remoteJid  String        @db.VarChar(100)
  pushName   String?
  status     SessionStatus
  awaitUser  Boolean       @default(false)
  createdAt  DateTime?     @default(now()) @db.Timestamp(6)
  updatedAt  DateTime      @updatedAt @db.Timestamp(6)
  instanceId String
  parameters Json?
  context    Json?
  botId      String?
  type       String?       @db.VarChar(100)
  Instance   Instance      @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  Message    Message[]
}

model OpenaiSetting {
  id               String      @id @default(cuid())
  expire           Int?        @default(0)
  keywordFinish    String?     @db.VarChar(100)
  delayMessage     Int?
  unknownMessage   String?     @db.VarChar(100)
  listeningFromMe  Boolean?    @default(false)
  stopBotFromMe    Boolean?    @default(false)
  keepOpen         Boolean?    @default(false)
  debounceTime     Int?
  ignoreJids       Json?
  createdAt        DateTime?   @default(now()) @db.Timestamp(6)
  updatedAt        DateTime    @updatedAt @db.Timestamp(6)
  openaiCredsId    String      @unique
  openaiIdFallback String?     @db.VarChar(100)
  instanceId       String      @unique
  speechToText     Boolean?    @default(false)
  splitMessages    Boolean?    @default(false)
  timePerChar      Int?        @default(50)
  Instance         Instance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  OpenaiCreds      OpenaiCreds @relation(fields: [openaiCredsId], references: [id])
  Fallback         OpenaiBot?  @relation(fields: [openaiIdFallback], references: [id])
}

model Template {
  id         String    @id @default(cuid())
  templateId String    @unique @db.VarChar(255)
  name       String    @unique @db.VarChar(255)
  template   Json
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime  @updatedAt @db.Timestamp(6)
  instanceId String
  webhookUrl String?   @db.VarChar(500)
  Instance   Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model Dify {
  id              String           @id @default(cuid())
  enabled         Boolean          @default(true)
  botType         DifyBotType
  apiUrl          String?          @db.VarChar(255)
  apiKey          String?          @db.VarChar(255)
  expire          Int?             @default(0)
  keywordFinish   String?          @db.VarChar(100)
  delayMessage    Int?
  unknownMessage  String?          @db.VarChar(100)
  listeningFromMe Boolean?         @default(false)
  stopBotFromMe   Boolean?         @default(false)
  keepOpen        Boolean?         @default(false)
  debounceTime    Int?
  ignoreJids      Json?
  triggerType     TriggerType?
  triggerOperator TriggerOperator?
  triggerValue    String?
  createdAt       DateTime?        @default(now()) @db.Timestamp(6)
  updatedAt       DateTime         @updatedAt @db.Timestamp(6)
  instanceId      String
  description     String?          @db.VarChar(255)
  splitMessages   Boolean?         @default(false)
  timePerChar     Int?             @default(50)
  Instance        Instance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  DifySetting     DifySetting[]
}

model DifySetting {
  id              String    @id @default(cuid())
  expire          Int?      @default(0)
  keywordFinish   String?   @db.VarChar(100)
  delayMessage    Int?
  unknownMessage  String?   @db.VarChar(100)
  listeningFromMe Boolean?  @default(false)
  stopBotFromMe   Boolean?  @default(false)
  keepOpen        Boolean?  @default(false)
  debounceTime    Int?
  ignoreJids      Json?
  createdAt       DateTime? @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  difyIdFallback  String?   @db.VarChar(100)
  instanceId      String    @unique
  splitMessages   Boolean?  @default(false)
  timePerChar     Int?      @default(50)
  Fallback        Dify?     @relation(fields: [difyIdFallback], references: [id])
  Instance        Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
}

model EvolutionBot {
  id                  String                @id @default(cuid())
  enabled             Boolean               @default(true)
  description         String?               @db.VarChar(255)
  apiUrl              String?               @db.VarChar(255)
  apiKey              String?               @db.VarChar(255)
  expire              Int?                  @default(0)
  keywordFinish       String?               @db.VarChar(100)
  delayMessage        Int?
  unknownMessage      String?               @db.VarChar(100)
  listeningFromMe     Boolean?              @default(false)
  stopBotFromMe       Boolean?              @default(false)
  keepOpen            Boolean?              @default(false)
  debounceTime        Int?
  ignoreJids          Json?
  triggerType         TriggerType?
  triggerOperator     TriggerOperator?
  triggerValue        String?
